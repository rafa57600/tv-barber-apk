# Firebase Configuration (for Database & Auth)
# Get these values from your Firebase project console
# https://console.firebase.google.com/

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Brevo Email Service Configuration
# Get your API key from: https://app.brevo.com/settings/keys/api
# 1. Create an account at https://www.brevo.com/
# 2. Go to Settings > API Keys > Generate API Key
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_NAME=Barber SHOP
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# App URL (for calendar links in emails)
# Use your production domain when deployed
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Cloud Messaging (Push Notifications)
# Get VAPID key from Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-firebase-vapid-key

# Firebase Admin SDK (for sending notifications from server)
# Download service account JSON from Firebase Console > Project Settings > Service accounts
# Set path to the JSON file (relative to project root) or paste the JSON inline
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Spotify Web Playback SDK
# Create an app at https://developer.spotify.com/dashboard
# Add redirect URI: https://yourdomain.com/api/spotify/callback
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_REDIRECT_URI=https://yourdomain.com/api/spotify/callback
